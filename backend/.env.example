# =========================================================================
# EpidemiTracker - Configuration d'environnement
# Copier ce fichier en .env et adapter aux environnements.
# JAMAIS commiter de .env réel.
# =========================================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-please-generate-a-50-char-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web,api.veillesanitaire.com,admin.veillesanitaire.com,destinationci.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://api.veillesanitaire.com,https://admin.veillesanitaire.com,https://destinationci.com
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,https://destinationci.com,https://admin.veillesanitaire.com
DJANGO_TIME_ZONE=Africa/Abidjan
DJANGO_LANGUAGE_CODE=fr-fr

# --- Database (Postgres + PostGIS) ---
POSTGRES_DB=epidemitracker
POSTGRES_USER=epidemi
POSTGRES_PASSWORD=epidemi
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgis://epidemi:epidemi@db:5432/epidemitracker

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CHANNEL_REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3
CACHE_URL=redis://redis:6379/4

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MIN=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_SIGNING_KEY=
JWT_ALGORITHM=HS256

# --- Health Pass / QR signing (Ed25519) ---
# Chemins (in container) vers les clés Ed25519 PEM utilisées pour signer/vérifier les pass.
# Générer avec : python manage.py generate_pass_keys
HEALTHPASS_PRIVATE_KEY_PATH=/app/keys/healthpass_ed25519_private.pem
HEALTHPASS_PUBLIC_KEY_PATH=/app/keys/healthpass_ed25519_public.pem
HEALTHPASS_ISSUER=MINSAN-CI
HEALTHPASS_DEFAULT_TTL_DAYS=30

# --- Notifications providers ---
# Email (Anymail / SMTP)
B8^rhTKe9sW

EMAIL_BACKEND=anymail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@epidemitracker.ci
ANYMAIL_SENDGRID_API_KEY=
# SMS / WhatsApp providers (configurer en prod)
SMS_PROVIDER=stub        # stub | twilio | orange_ci
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
WHATSAPP_PROVIDER=stub   # stub | twilio | meta
WHATSAPP_FROM_NUMBER=
# Push (FCM)
FCM_SERVER_KEY=

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=epidemitracker-api
LOG_LEVEL=INFO

# --- Sécurité ---
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
SECURE_HSTS_SECONDS=0

# --- App ---
COUNTRY_CODE=CI
NATIONAL_ORG_NAME=Ministère de la Santé - Côte d'Ivoire
INHP_ORG_NAME=Institut National d'Hygiène Publique
DEFAULT_QUARANTINE_DAYS=21

# --- Superuser bootstrap (utilisé par scripts d'init si défini) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@epidemitracker.local
DJANGO_SUPERUSER_PASSWORD=ChangeMe!2026
