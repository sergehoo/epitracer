# =========================================================================
# Backend Django — Configuration pour développement LOCAL natif
# (sans Docker — Postgres/Redis installés via Homebrew sur macOS)
#
# Copier ce fichier en backend/.env pour lancer `python manage.py runserver`.
# =========================================================================

DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=local-dev-secret-change-me-please-50-characters-min
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,publictraveler.lvh.me,admin.lvh.me,api.lvh.me
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://publictraveler.lvh.me,http://admin.lvh.me
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://publictraveler.lvh.me,http://admin.lvh.me
DJANGO_TIME_ZONE=Africa/Abidjan
DJANGO_LANGUAGE_CODE=fr-fr

# --- Postgres+PostGIS local (brew) ---
POSTGRES_DB=epidemiebola
POSTGRES_USER=epidemi
POSTGRES_PASSWORD=epidemi
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgis://epidemi:epidemi@localhost:5432/epidemiebola

# --- Redis local (brew) ---
REDIS_URL=redis://localhost:6379/0
CHANNEL_REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3
CACHE_URL=redis://localhost:6379/4

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MIN=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ALGORITHM=HS256

# --- Health Pass ---
HEALTHPASS_PRIVATE_KEY_PATH=./keys/healthpass_ed25519_private.pem
HEALTHPASS_PUBLIC_KEY_PATH=./keys/healthpass_ed25519_public.pem
HEALTHPASS_ISSUER=MINSAN-CI-DEV
HEALTHPASS_DEFAULT_TTL_DAYS=30

# --- Notifications (stub en dev = log uniquement) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@epitravel.local
SMS_PROVIDER=stub
WHATSAPP_PROVIDER=stub

# --- Sécurité dev (relâchée) ---
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
SECURE_HSTS_SECONDS=0

# --- App ---
COUNTRY_CODE=CI
NATIONAL_ORG_NAME=Ministère de la Santé - Côte d'Ivoire
INHP_ORG_NAME=Institut National d'Hygiène Publique
DEFAULT_QUARANTINE_DAYS=21

LOG_LEVEL=INFO
