# ============================================================
# Mon Pass Sanitaire — Configuration mobile
# Copier ce fichier en .env (jamais commité) et remplir les valeurs.
# Pour switcher entre prod et staging, utiliser scripts/build_apk.sh
# qui copie automatiquement .env.production ou .env.staging vers .env
# ============================================================

# Environnement actif : production | staging
# Affecte le bandeau visible et certains comportements de logging.
ENVIRONMENT=production

# URL de l'API backend EpiTrace
API_BASE_URL=https://api.veillesanitaire.com/api/v1
API_MOBILE_BASE_URL=https://api.veillesanitaire.com/api/mobile

# Domaine public Destination CI (pour les liens externes)
PUBLIC_WEB_BASE_URL=https://destinationci.com
PUBLIC_HOST=https://destinationci.com

# Numéros d'assistance
EMERGENCY_NUMBER=143
HEALTH_INFO_NUMBER=185

# Firebase Cloud Messaging (clé serveur — laisser vide en dev)
FCM_SERVER_KEY=

# Clé publique Ed25519 pour vérifier les pass hors-ligne (au format hex)
# Doit correspondre à HEALTHPASS_PUBLIC_KEY côté backend
PASS_PUBLIC_KEY_HEX=

# Mode debug
DEBUG=false
LOG_LEVEL=info
