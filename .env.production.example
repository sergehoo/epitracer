# =========================================================================
# EpiTrace — .env PRODUCTION
#
# À copier : cp .env.production.example .env
# Puis : éditer toutes les valeurs marquées CHANGE_ME / TODO.
#
# Ce fichier est lu par docker-compose au moment du `up -d`. Toutes les
# variables sont substituées dans docker-compose.yml + docker-compose.prod.yml.
# JAMAIS commiter de .env réel — il est ignoré par .gitignore.
# =========================================================================

# -------------------------------------------------------------------------
#                       TRAEFIK EXTERNE (déjà en place)
# -------------------------------------------------------------------------
TRAEFIK_NETWORK=proxy
TRAEFIK_CERT_RESOLVER=lets

# -------------------------------------------------------------------------
#                       DOMAINES PUBLICS
# -------------------------------------------------------------------------
# Portail PUBLIC voyageurs (sans logos institutionnels en topbar)
PUBLIC_HOST=destinationci.com

# Portail ADMIN (avec les 3 logos officiels MSHPCMU/INHP/Armoiries CI)
ADMIN_HOST=admin.veillesanitaire.com

# API REST Django (consommée par les 2 portails + agents mobiles)
API_HOST=api.veillesanitaire.com

# WebSocket Channels (dashboard temps réel) — sur le même domaine que l'API
# via Traefik (path /ws/) OU sous-domaine dédié si besoin.
WS_HOST=api.veillesanitaire.com

# Grafana (interne — retirer les labels Traefik dans prod.yml si non exposé)
GRAFANA_HOST=grafana.veillesanitaire.com

# -------------------------------------------------------------------------
#                       DJANGO (settings prod)
# -------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_DEBUG=0

# Génération de la clé : python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE_ME_avec_au_moins_64_caracteres_random_obligatoire_en_prod

DJANGO_ALLOWED_HOSTS=api.veillesanitaire.com,admin.veillesanitaire.com,destinationci.com,www.destinationci.com,web,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.veillesanitaire.com,https://admin.veillesanitaire.com,https://destinationci.com,https://www.destinationci.com
DJANGO_CORS_ALLOWED_ORIGINS=https://destinationci.com,https://www.destinationci.com,https://admin.veillesanitaire.com

DJANGO_TIME_ZONE=Africa/Abidjan
DJANGO_LANGUAGE_CODE=fr-fr
LOG_LEVEL=INFO

# Sécurité durcie (HTTPS, cookies sécurisés, HSTS 1 an)
SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_HSTS_SECONDS=31536000

# -------------------------------------------------------------------------
#                       POSTGRES + POSTGIS
# -------------------------------------------------------------------------
# Le container `db` écoute sur le réseau interne uniquement (pas d'exposition
# hôte en prod). Les credentials peuvent être forts car ils restent internes.
POSTGRES_DB=epitrace
POSTGRES_USER=epitrace
POSTGRES_PASSWORD=CHANGE_ME_mdp_postgres_fort

# Construction du DSN — laisser comme tel
DATABASE_URL=postgis://epitrace:CHANGE_ME_mdp_postgres_fort@db:5432/epitrace

# -------------------------------------------------------------------------
#                       REDIS (interne)
# -------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CHANNEL_REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3
CACHE_URL=redis://redis:6379/4

# -------------------------------------------------------------------------
#                       JWT (auth agents INHP)
# -------------------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MIN=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ALGORITHM=HS256
# Vide = utilise DJANGO_SECRET_KEY ci-dessus (recommandé)
JWT_SIGNING_KEY=

# -------------------------------------------------------------------------
#                       HEALTH PASS — CLÉS ED25519
# -------------------------------------------------------------------------
# Générer une fois :
#   docker compose exec web python manage.py generate_pass_keys
# Les fichiers sont stockés dans le volume `keys_data` (persistant).
HEALTHPASS_PRIVATE_KEY_PATH=/app/keys/healthpass_ed25519_private.pem
HEALTHPASS_PUBLIC_KEY_PATH=/app/keys/healthpass_ed25519_public.pem
HEALTHPASS_ISSUER=MSHPCMU-CI
HEALTHPASS_DEFAULT_TTL_DAYS=30

# -------------------------------------------------------------------------
#                       EMAIL — DUAL SENDER (multi-expéditeur)
# -------------------------------------------------------------------------
# Système 2 expéditeurs strictement séparés (routing automatique par
# EmailRouter selon EmailType — le frontend ne choisit JAMAIS) :
#
#   PUBLIC   → infos@destinationci.com     via Amazon SES SMTP
#   INTERNAL → inhp@veillesanitaire.com   via SMTP serveur local
#
# Voir docs/EMAIL_MULTI_SENDER_SETUP.md pour les étapes DNS + AWS SES.

# Backend Django par défaut — fallback uniquement (les envois métier
# passent par EmailRouter qui ouvre ses propres connexions SMTP).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=EpiTrace <no-reply@veillesanitaire.com>

# ── PROFIL PUBLIC — Amazon SES (destinationci.com) ──────────────────────
# Étapes : 1) Créer/valider domaine destinationci.com dans SES
#          2) Publier DNS DKIM (3 CNAME) + SPF (TXT) + DMARC
#          3) Sortir du sandbox SES (production access request)
#          4) Créer credentials SMTP SES → username + password
PUBLIC_EMAIL_HOST=email-smtp.eu-west-1.amazonaws.com
PUBLIC_EMAIL_PORT=587
PUBLIC_EMAIL_USE_TLS=true
PUBLIC_EMAIL_USE_SSL=false
PUBLIC_EMAIL_HOST_USER=CHANGE_ME_ses_smtp_username
PUBLIC_EMAIL_HOST_PASSWORD=CHANGE_ME_ses_smtp_password
PUBLIC_EMAIL_FROM_NAME=Destination CI - Accompagnement Voyageur
PUBLIC_EMAIL_FROM_ADDRESS=infos@destinationci.com
DEFAULT_REPLY_TO_PUBLIC=infos@destinationci.com
PUBLIC_EMAIL_TIMEOUT=20

# ── PROFIL INTERNAL — SMTP serveur local (veillesanitaire.com) ──────────
# Utilise le serveur SMTP installé sur la VM (Postfix par exemple) OU un
# relai SMTP authentifié (OVH MX Plan, Brevo, Mailjet, etc.).
INTERNAL_EMAIL_HOST=smtp.veillesanitaire.com
INTERNAL_EMAIL_PORT=587
INTERNAL_EMAIL_USE_TLS=true
INTERNAL_EMAIL_USE_SSL=false
INTERNAL_EMAIL_HOST_USER=inhp@veillesanitaire.com
INTERNAL_EMAIL_HOST_PASSWORD=CHANGE_ME_smtp_serveur_password
INTERNAL_EMAIL_FROM_NAME=INHP - Veille Sanitaire
INTERNAL_EMAIL_FROM_ADDRESS=inhp@veillesanitaire.com
DEFAULT_REPLY_TO_INTERNAL=inhp@veillesanitaire.com
INTERNAL_EMAIL_TIMEOUT=20

# ── URL de connexion admin (incluse dans les emails de création compte) ─
ADMIN_LOGIN_URL=https://admin.veillesanitaire.com/auth/login

# ── Durée de validité des tokens de reset password (heures) ─────────────
PASSWORD_RESET_TOKEN_TTL_HOURS=24

# ── Legacy SendGrid (gardé pour compat, peut rester vide en dual SMTP) ──
ANYMAIL_SENDGRID_API_KEY=

# -------------------------------------------------------------------------
#                       SMS / WhatsApp / PUSH
# -------------------------------------------------------------------------
# Stratégie : "auto" → numéros +225 routés vers Orange CI, autres → Twilio
SMS_PROVIDER=auto

# ── Orange Côte d'Ivoire (SMS Bulk OneAPI) ──────────────────────────────
# Mettre ORANGE_CI_SMS_ENABLED=true UNIQUEMENT après passage en mode
# PRODUCTION chez Orange Business CI (voir docs/ORANGE_CI_SANDBOX_TO_PROD.md).
ORANGE_CI_SMS_ENABLED=false
ORANGE_CI_SMS_CLIENT_ID=CHANGE_ME_orange_client_id
ORANGE_CI_SMS_CLIENT_SECRET=CHANGE_ME_orange_client_secret
# MSISDN émetteur du contrat Orange CI — OBLIGATOIRE (E.164 avec +225).
# C'est le numéro de téléphone fourni par Orange à la souscription, pas
# le sender ID alphanumérique. Le payload OneAPI exige un vrai MSISDN ici.
ORANGE_CI_SMS_SENDER_MSISDN=+2250000000000
# Sender ID alphanumérique affiché chez le destinataire (5-11 caractères).
# Doit être validé par Orange Business CI avant utilisation en production.
ORANGE_CI_SMS_SENDER_NAME=INHP
# URL du webhook delivery report — Orange CI doit l'enregistrer côté plateforme.
ORANGE_CI_SMS_CALLBACK_URL=https://api.veillesanitaire.com/api/v1/notifications/webhooks/orange-ci/sms/status/
# Token statique partagé avec Orange pour authentifier les pushes vers le webhook.
# Générer : openssl rand -hex 32
ORANGE_CI_WEBHOOK_TOKEN=CHANGE_ME_random_hex_32

# ── Twilio (SMS international + WhatsApp fallback) ──────────────────────
TWILIO_SMS_ENABLED=true
TWILIO_ACCOUNT_SID=CHANGE_ME_twilio_sid
TWILIO_AUTH_TOKEN=CHANGE_ME_twilio_token
TWILIO_FROM_NUMBER=+22500000000

# ── WhatsApp (Twilio par défaut, Meta Cloud API en alternative) ─────────
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=twilio
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_FROM_NUMBER=+14155238886

# Meta Cloud API (à activer si WHATSAPP_PROVIDER=meta_whatsapp)
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_APP_SECRET=

# ── Push Web (FCM legacy) ───────────────────────────────────────────────
FCM_SERVER_KEY=CHANGE_ME_firebase_key

# -------------------------------------------------------------------------
#                       OBSERVABILITÉ
# -------------------------------------------------------------------------
SENTRY_DSN=https://CHANGE_ME@oXXXXX.ingest.sentry.io/XXXXX
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05

# OpenTelemetry (optionnel — laisser vide pour désactiver)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=epitrace-api

GRAFANA_PASSWORD=CHANGE_ME_mdp_grafana_admin

# -------------------------------------------------------------------------
#                       APP METADATA (affichage)
# -------------------------------------------------------------------------
COUNTRY_CODE=CI
NATIONAL_ORG_NAME=MSHPCMU
INHP_ORG_NAME=Institut National d'Hygiène Publique
DEFAULT_QUARANTINE_DAYS=21

# -------------------------------------------------------------------------
#                       SUPERUSER BOOTSTRAP (optionnel)
# -------------------------------------------------------------------------
# Si défini, `seed_reference_data` créera ce compte au premier passage.
DJANGO_SUPERUSER_USERNAME=admin@veillesanitaire.com
DJANGO_SUPERUSER_EMAIL=admin@veillesanitaire.com
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME_admin_temporaire_a_modifier

# -------------------------------------------------------------------------
#                       SÉCURITÉ P0 — task #213
# -------------------------------------------------------------------------
# Content-Security-Policy
#   - false → enforce (recommandé en prod)
#   - true  → report-only (rollback à chaud sans redéploiement)
CSP_REPORT_ONLY=false
# Endpoint optionnel pour collecter les violations CSP.
# Ex: https://api.veillesanitaire.com/api/v1/security/csp-report/
CSP_REPORT_URI=
# Origines connect-src additionnelles (CSV). Override la valeur par défaut
# si besoin d'autoriser un domaine tiers (analytics, etc.).
# CSP_CONNECT_SRC='self',https://api.veillesanitaire.com,wss://api.veillesanitaire.com

# Validation uploads voyageurs
MAX_UPLOAD_SIZE_MB=5
# Liste blanche MIME — séparateur virgule
ALLOWED_UPLOAD_MIMES=image/jpeg,image/png,image/webp,application/pdf

# Chiffrement at-rest PII (django-cryptography Fernet)
# La première clé sert au chiffrement ; toutes sont essayées en déchiffrement.
# Générer une nouvelle clé via :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ROTATION : ajouter la nouvelle clé EN TÊTE, garder l'ancienne pendant
# la durée de la migration, puis retirer l'ancienne via
# `python manage.py migrate_pii_to_encrypted` (re-écrit avec la nouvelle clé).
DJANGO_FERNET_KEYS=CHANGE_ME_fernet_key_base64_44_chars=
DJANGO_CRYPTOGRAPHY_SALT=epitrace.cryptography
