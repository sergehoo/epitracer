# =========================================================================
# EpiTrace — .env STAGING (recette / pré-prod)
#
# Coexiste avec la PROD sur le même hôte grâce à `name: epitrace-staging`
# défini dans docker-compose.staging.yml — les containers, volumes et la
# base PostgreSQL sont strictement séparés de la prod.
#
# À copier sur le serveur :
#   cp .env.staging.example .env.staging
#   # Puis remplir toutes les valeurs CHANGE_ME / TODO.
#
# Lancer la stack staging :
#   docker compose --env-file .env.staging \
#       -f docker-compose.yml -f docker-compose.staging.yml up -d --build
#
# JAMAIS commiter ce fichier rempli — il est ignoré par .gitignore.
# =========================================================================

# -------------------------------------------------------------------------
#                       TRAEFIK (mutualisé avec la prod)
# -------------------------------------------------------------------------
# Même réseau / même resolver que la prod : Traefik gère les 2 environnements
# côte à côte. C'est l'isolation par hostname (staging.* vs apex) qui fait
# le routage.
TRAEFIK_NETWORK=proxy
TRAEFIK_CERT_RESOLVER=lets

# -------------------------------------------------------------------------
#                       DOMAINES STAGING
# -------------------------------------------------------------------------
# DNS à provisionner : 3 records A pointant vers l'IP du serveur prod.
PUBLIC_HOST=staging.destinationci.com
ADMIN_HOST=admin-staging.veillesanitaire.com
API_HOST=api-staging.veillesanitaire.com

# -------------------------------------------------------------------------
#                       AUTHENTIFICATION BASIQUE HTTP
# -------------------------------------------------------------------------
# Empêche l'indexation Google + l'accès anonyme. Tous les domaines staging
# sont protégés sauf les WebSocket (qui utilisent le JWT applicatif).
#
# Générer la valeur (utilisateur "inhp", mot de passe au choix) :
#   htpasswd -nbB inhp 'monMotDePasseStaging' | sed 's/\$/\$\$/g'
#
# Le `sed` double les $ (échappement docker-compose). Le résultat
# ressemble à : inhp:$$2y$$05$$abcdefghijk...
STAGING_BASIC_AUTH=CHANGE_ME_inhp:$$2y$$05$$REMPLACER_PAR_LE_HASH_BCRYPT_GENERE

# -------------------------------------------------------------------------
#                       DJANGO (settings prod, env=staging)
# -------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_DEBUG=0
DJANGO_ENVIRONMENT=staging

# Clé distincte de la prod — régénérer :
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE_ME_clé_staging_distincte_64_caracteres_minimum

DJANGO_TIME_ZONE=Africa/Abidjan
DJANGO_LANGUAGE_CODE=fr-fr
LOG_LEVEL=INFO

# HSTS court (60s) pour pouvoir basculer rapidement entre HTTP/HTTPS en QA
SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_HSTS_SECONDS=60

# -------------------------------------------------------------------------
#                       POSTGRESQL (volume séparé)
# -------------------------------------------------------------------------
# Le volume `epitrace-staging_db_data` est créé automatiquement et n'est
# JAMAIS partagé avec la prod. Pour repartir d'un dump anonymisé :
#   docker compose --env-file .env.staging -p epitrace-staging exec db \
#       psql -U epidemi epidemitracker < dump_anonymise.sql
DATABASE_URL=postgis://epidemi:epidemi@db:5432/epidemitracker

# -------------------------------------------------------------------------
#                       NOTIFICATIONS (DÉSACTIVÉES par défaut)
# -------------------------------------------------------------------------
# Bonne pratique en staging : pas d'envoi réel pour éviter de spammer les
# vrais numéros / vraies boîtes. Activer ponctuellement le canal à tester.
ORANGE_CI_SMS_ENABLED=false
TWILIO_SMS_ENABLED=false
WHATSAPP_ENABLED=false

# Si activation ponctuelle SMS Orange CI, utiliser des numéros TEST
# (ex: numéro perso) et garder le sender Orange CI réel :
# ORANGE_CI_SMS_CLIENT_ID=<même que prod ou compte dev dédié>
# ORANGE_CI_SMS_CLIENT_SECRET=<...>
# ORANGE_CI_SMS_SENDER_MSISDN=<MSISDN Orange CI>
# ORANGE_CI_SMS_SENDER_NAME=INHP-STG
# ORANGE_CI_SMS_CALLBACK_URL=https://api-staging.veillesanitaire.com/api/v1/notifications/webhooks/orange-ci/sms/status/

# -------------------------------------------------------------------------
#                       EMAILS → MAILHOG (capture locale)
# -------------------------------------------------------------------------
# Mailhog tourne dans la stack staging et capture TOUS les emails.
# Interface web : http://localhost:8025 (via tunnel SSH ou label Traefik
# ajouté manuellement si besoin de l'exposer).
PUBLIC_EMAIL_HOST=mailhog
PUBLIC_EMAIL_PORT=1025
PUBLIC_EMAIL_USE_TLS=false
PUBLIC_EMAIL_USE_SSL=false
PUBLIC_EMAIL_HOST_USER=
PUBLIC_EMAIL_HOST_PASSWORD=
PUBLIC_EMAIL_FROM_NAME=Destination CI - STAGING
PUBLIC_EMAIL_FROM_ADDRESS=staging@destinationci.com

INTERNAL_EMAIL_HOST=mailhog
INTERNAL_EMAIL_PORT=1025
INTERNAL_EMAIL_USE_TLS=false
INTERNAL_EMAIL_USE_SSL=false
INTERNAL_EMAIL_HOST_USER=
INTERNAL_EMAIL_HOST_PASSWORD=
INTERNAL_EMAIL_FROM_NAME=INHP - Staging
INTERNAL_EMAIL_FROM_ADDRESS=staging@veillesanitaire.com

ADMIN_LOGIN_URL=https://admin-staging.veillesanitaire.com/auth/login

# -------------------------------------------------------------------------
#                       HEALTHPASS Ed25519 (clé staging dédiée)
# -------------------------------------------------------------------------
# IMPORTANT : générer une nouvelle paire pour staging — les pass émis en
# staging NE DOIVENT JAMAIS être valides en prod (et inversement).
#   docker compose --env-file .env.staging -p epitrace-staging \
#       exec web python manage.py rotate_healthpass_keys --force
HEALTHPASS_ISSUER=MINSAN-CI-STAGING
NATIONAL_ORG_NAME=Ministère de la Santé (Staging)

# -------------------------------------------------------------------------
#                       VAPID (push Web)
# -------------------------------------------------------------------------
# Idem : nouvelle paire VAPID pour staging.
# Générer : python -c "from py_vapid import Vapid01; v=Vapid01(); v.generate_keys(); print('priv:', v.private_key.private_bytes(...)); print('pub:', v.public_key.public_bytes(...))"
VAPID_PUBLIC_KEY=CHANGE_ME_clé_publique_staging
VAPID_PRIVATE_KEY=CHANGE_ME_clé_privée_staging
VAPID_CLAIM_EMAIL=mailto:staging@veillesanitaire.com

# -------------------------------------------------------------------------
#                       SÉCURITÉ P0 (task #213) — staging
# -------------------------------------------------------------------------
# CSP en report-only sur staging pour mesurer les violations avant prod
CSP_REPORT_ONLY=true
CSP_REPORT_URI=

# Uploads
MAX_UPLOAD_SIZE_MB=5
ALLOWED_UPLOAD_MIMES=image/jpeg,image/png,image/webp,application/pdf

# Fernet keys staging — clé DIFFÉRENTE de la prod (pas de copie clé prod !)
DJANGO_FERNET_KEYS=CHANGE_ME_fernet_key_staging_base64=
DJANGO_CRYPTOGRAPHY_SALT=epitrace.cryptography.staging

# -------------------------------------------------------------------------
#                       TELEGRAM BOT — staging (bot distinct de la prod !)
# -------------------------------------------------------------------------
# Créer un bot séparé pour staging (@MonPassSanitaireINHPStaging_bot) pour
# éviter que des tests polluent les vrais chats en prod.
TELEGRAM_BOT_TOKEN=CHANGE_ME_staging_bot_token
TELEGRAM_BOT_USERNAME=MonPassSanitaireINHPStaging_bot
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_random_48chars_secret_staging
