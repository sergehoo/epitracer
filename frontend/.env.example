# =========================================================================
# Front Next.js — Portails séparés par domaine
# =========================================================================

# URL de l'API backend Django
# Dev local :       http://localhost:8000
# Production :      https://api.veillesanitaire.com
NEXT_PUBLIC_API_URL=https://api.veillesanitaire.com
NEXT_PUBLIC_WS_URL=wss://api.veillesanitaire.com

# --- Domaines de production ---
# Portail public voyageurs : destinationci.com
# Portail admin            : admin.veillesanitaire.com
NEXT_PUBLIC_PUBLIC_HOST=destinationci.com
NEXT_PUBLIC_ADMIN_HOST=admin.veillesanitaire.com

# Branding affiché
NEXT_PUBLIC_PORTAL_NAME=EpiTrace
NEXT_PUBLIC_PORTAL_NAME_PUBLIC=Destination Côte d'Ivoire
NEXT_PUBLIC_PORTAL_NAME_ADMIN=EpiTrace — Admin INHP
NEXT_PUBLIC_PORTAL_TAGLINE=Portail National de Surveillance des Voyageurs

# Numéros d'urgence affichés
NEXT_PUBLIC_INHP_PHONES=143
NEXT_PUBLIC_SAMU=185
NEXT_PUBLIC_ALLO_SANTE=143
NEXT_PUBLIC_SECOURS=101
