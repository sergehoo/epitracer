# =========================================================================
# Front Next.js — Portails séparés par domaine
# =========================================================================

# URL de l'API backend Django
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8001

# --- Domaines de production ---
# Portail public voyageurs : publictraveler.ci
# Portail admin INHP       : inhpadmin.ci
NEXT_PUBLIC_PUBLIC_HOST=publictraveler.ci
NEXT_PUBLIC_ADMIN_HOST=inhpadmin.ci

# Branding affiché
NEXT_PUBLIC_PORTAL_NAME=EpiTravel
NEXT_PUBLIC_PORTAL_NAME_PUBLIC=EpiTravel
NEXT_PUBLIC_PORTAL_NAME_ADMIN=EpiTravel — Admin INHP
NEXT_PUBLIC_PORTAL_TAGLINE=Portail National de Surveillance des Voyageurs

# Numéros d'urgence affichés
NEXT_PUBLIC_INHP_PHONES=27 21 25 35 10,27 21 25 97 46
NEXT_PUBLIC_SAMU=185
NEXT_PUBLIC_ALLO_SANTE=143
NEXT_PUBLIC_SECOURS=101
